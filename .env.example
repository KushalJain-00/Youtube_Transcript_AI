# ─── YT.AI Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Required in production — keeps sessions alive across restarts.
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# Optional — defaults to 5000
PORT=5000

# Set to "production" on your hosting platform
FLASK_ENV=production

# Set to "1" to enable debug mode (local dev only, NEVER in production)
FLASK_DEBUG=0

# Optional — custom database path
# DB_PATH=ytai_data.db
